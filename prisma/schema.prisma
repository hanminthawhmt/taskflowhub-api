// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ==========================================
// USERS & AUTH
// ==========================================

model User {
  id           Int          @id @default(autoincrement())
  name         String       @db.VarChar(255)
  email        String       @unique @db.VarChar(255)
  password     String       @db.VarChar(255)
  platformRole PlatformRole @default(user) @map("platform_role")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  companiesCreated   Company[]           @relation("CompanyCreatedBy")
  projectsCreated    Project[]           @relation("ProjectCreatedBy")
  companyMemberships CompanyMember[]
  companyInvitesSent CompanyInvitation[] @relation("CompanyInvitedBy")
  projectMemberships ProjectMember[]
  projectInvitesSent ProjectInvitation[] @relation("ProjectInvitedBy")
  tasksAssigned      Task[]              @relation("TaskAssignee")
  tasksCreated       Task[]              @relation("TaskCreatedBy")
  activityLogs       ActivityLog[]

  @@map("users")
}

enum PlatformRole {
  super_admin
  user
}

// ==========================================
// ROLES & PERMISSIONS (RBAC)
// ==========================================

model Role {
  id        Int       @id @default(autoincrement())
  title     String    @db.VarChar(255)
  scope     RoleScope
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  rolePermissions    RolePermission[]
  companyMembers     CompanyMember[]
  companyInvitations CompanyInvitation[]
  projectMembers     ProjectMember[]
  projectInvitations ProjectInvitation[]

  @@map("roles")
}

enum RoleScope {
  company
  project
}

model Permission {
  id        Int      @id @default(autoincrement())
  name      String   @unique @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           Int      @id @default(autoincrement())
  roleId       Int      @map("role_id")
  permissionId Int      @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@map("role_permissions")
}

// ==========================================
// COMPANIES
// ==========================================

model Company {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(255)
  createdBy          Int       @map("created_by")
  planId             Int?      @map("plan_id")
  stripeId           String?   @map("stripe_id") @db.VarChar(255)
  pmType             String?   @map("pm_type") @db.VarChar(255)
  pmLastFour         String?   @map("pm_last_four") @db.VarChar(4)
  trialEndsAt        DateTime? @map("trial_ends_at")
  subscriptionStatus String    @map("subscription_status") @db.VarChar(255)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  creator       User                @relation("CompanyCreatedBy", fields: [createdBy], references: [id])
  plan          Plan?               @relation(fields: [planId], references: [id])
  members       CompanyMember[]
  invitations   CompanyInvitation[]
  projects      Project[]
  subscriptions Subscription[]

  @@map("companies")
}

model CompanyMember {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  userId    Int       @map("user_id")
  roleId    Int       @map("role_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([companyId, userId])
  @@map("company_members")
}

model CompanyInvitation {
  id         Int              @id @default(autoincrement())
  companyId  Int              @map("company_id")
  email      String           @db.VarChar(255)
  roleId     Int              @map("role_id")
  token      String?          @db.VarChar(255)
  status     InvitationStatus @default(pending)
  invitedBy  Int              @map("invited_by")
  expiresAt  DateTime?        @map("expires_at")
  acceptedAt DateTime?        @map("accepted_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])
  inviter User    @relation("CompanyInvitedBy", fields: [invitedBy], references: [id])

  @@map("company_invitations")
}

enum InvitationStatus {
  pending
  accepted
  declined
  expired
  cancelled
}

// ==========================================
// PROJECTS
// ==========================================

model Project {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  title       String   @db.VarChar(255)
  description String?  @db.Text
  createdBy   Int      @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company             @relation(fields: [companyId], references: [id])
  creator     User                @relation("ProjectCreatedBy", fields: [createdBy], references: [id])
  members     ProjectMember[]
  invitations ProjectInvitation[]
  tasks       Task[]

  @@map("projects")
}

model ProjectMember {
  id        Int       @id @default(autoincrement())
  projectId Int       @map("project_id")
  userId    Int       @map("user_id")
  roleId    Int       @map("role_id")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectInvitation {
  id         Int              @id @default(autoincrement())
  projectId  Int              @map("project_id")
  email      String           @db.VarChar(255)
  roleId     Int              @map("role_id")
  token      String?          @db.VarChar(255)
  status     InvitationStatus @default(pending)
  invitedBy  Int              @map("invited_by")
  expiresAt  DateTime?        @map("expires_at")
  acceptedAt DateTime?        @map("accepted_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  updatedAt  DateTime         @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  role    Role    @relation(fields: [roleId], references: [id])
  inviter User    @relation("ProjectInvitedBy", fields: [invitedBy], references: [id])

  @@map("project_invitations")
}

// ==========================================
// TASKS
// ==========================================

model Task {
  id          Int           @id @default(autoincrement())
  projectId   Int           @map("project_id")
  userId      Int           @map("user_id")
  createdBy   Int           @map("created_by")
  title       String        @db.VarChar(255)
  description String?       @db.Text
  priority    TaskPriority?
  status      TaskStatus    @default(pending)
  startDate   DateTime?     @map("start_date")
  endDate     DateTime?     @map("end_date")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  project Project @relation(fields: [projectId], references: [id])
  user    User    @relation("TaskAssignee", fields: [userId], references: [id])
  creator User    @relation("TaskCreatedBy", fields: [createdBy], references: [id])

  @@map("tasks")
}

enum TaskPriority {
  high
  medium
  low
}

enum TaskStatus {
  pending
  complete
}

// ==========================================
// BILLING (PLANS, SUBSCRIPTIONS, SUBSCRIPTION ITEMS)
// ==========================================

model Plan {
  id            Int      @id @default(autoincrement())
  name          String   @unique @db.VarChar(255)
  price         Int
  stripePriceId String?  @map("stripe_price_id") @db.VarChar(255)
  maxProjects   Int?     @map("max_projects")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  companies     Company[]
  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id           Int       @id @default(autoincrement())
  companyId    Int       @map("company_id")
  planId       Int?      @map("plan_id")
  type         String    @db.VarChar(255)
  stripeId     String?   @map("stripe_id") @db.VarChar(255)
  stripeStatus String?   @map("stripe_status") @db.VarChar(255)
  stripePrice  String?   @map("stripe_price") @db.VarChar(255)
  quantity     Int?      @db.Int
  trialEndsAt  DateTime? @map("trial_ends_at")
  endsAt       DateTime? @map("ends_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  company Company            @relation(fields: [companyId], references: [id])
  plan    Plan?              @relation(fields: [planId], references: [id])
  items   SubscriptionItem[]

  @@map("subscriptions")
}

model SubscriptionItem {
  id             Int      @id @default(autoincrement())
  subscriptionId Int      @map("subscription_id")
  stripeId       String   @map("stripe_id") @db.VarChar(255)
  stripeProduct  String   @map("stripe_product") @db.VarChar(255)
  stripePrice    String?  @map("stripe_price") @db.VarChar(255)
  meterId        String?  @map("meter_id") @db.VarChar(255)
  quantity       Int?
  meterEventName String?  @map("meter_event_name") @db.VarChar(255)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("subscription_items")
}

// ==========================================
// ACTIVITY LOGS
// ==========================================

model ActivityLog {
  id          Int      @id @default(autoincrement())
  companyId   Int?     @map("company_id")
  projectId   Int?     @map("project_id")
  userId      Int      @map("user_id")
  action      String?  @db.VarChar(255)
  subjectType String?  @map("subject_type") @db.VarChar(255)
  subjectId   Int?     @map("subject_id")
  meta        Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("activity_logs")
}
