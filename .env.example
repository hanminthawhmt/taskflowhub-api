# Server
PORT=3000
APP_URL=
# Database
# When running locally without Docker, point this at your own MySQL instance.
# When running via Docker Compose, this gets overridden automatically — see docker-compose.yml.
DATABASE_URL=mysql://root:password@localhost:3306/task_management

# Auth
JWT_SECRET= 
JWT_EXPIRES_IN=7d

# Email (Mailtrap sandbox — https://mailtrap.io)
MAILTRAP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_PORT=2525
MAILTRAP_USER=
MAILTRAP_PASS=
MAIL_FROM="Task Management <no-reply@taskmanagement.dev>"

# Stripe (use your test-mode keys — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Super admin bootstrap (used once by prisma/seeds/superadmin.seed.js)
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin

# Docker Compose only — sets up the MySQL container
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=task_management